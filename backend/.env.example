# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
# Local MongoDB (for development)
# MONGODB_URI=mongodb://localhost:27017/afrochinatrade

# MongoDB Atlas (replace with your actual connection string)
# Get this from MongoDB Atlas: Connect -> Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/afrochinatrade?retryWrites=true&w=majority

# JWT Configuration
# IMPORTANT: Generate a strong, random secret key (minimum 32 characters)
# Use: openssl rand -base64 32
# Never use default values in production!
JWT_SECRET=your-secret-key-here-change-in-production-minimum-32-chars
JWT_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19000,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security Configuration
# Add any additional security-related environment variables here

# Expo Push Notifications (optional)
EXPO_ACCESS_TOKEN=your-expo-access-token-here
