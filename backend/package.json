{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:prod": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:seed": "ts-node src/scripts/seedAll.ts",
    "db:seed:categories": "ts-node src/scripts/seedCategories.ts",
    "db:seed:admin": "ts-node src/scripts/seedAdmin.ts",
    "db:seed:sample": "ts-node src/scripts/seedSampleData.ts",
    "db:seed:category-products": "ts-node src/scripts/seedAdditionalCategoryProducts.ts",
    "db:import:category-products": "ts-node src/scripts/importCategoryProductsFromJSON.ts",
    "db:migrate:products": "ts-node src/scripts/migrateProducts.ts",
    "db:migrate:users": "ts-node src/scripts/migrateUsers.ts",
    "db:clear": "ts-node src/scripts/clearDatabase.ts",
    "db:clear:confirm": "ts-node src/scripts/clearDatabase.ts --confirm",
    "db:clear:products": "ts-node src/scripts/clearProducts.ts",
    "db:clear:carts": "ts-node src/scripts/clearAllCarts.ts",
    "db:clear:products:confirm": "ts-node src/scripts/clearProducts.ts --confirm",
    "db:health": "ts-node src/scripts/healthCheck.ts",
    "db:verify": "ts-node src/scripts/verifyIndexes.ts",
    "db:sync:reviews": "ts-node src/scripts/syncProductReviews.ts",
    "db:fix:reviews": "ts-node src/scripts/fixReviewDiscrepancies.ts",
    "db:seed:collections": "ts-node src/scripts/seedCollections.ts",
    "db:seed:advanced-collections": "ts-node src/scripts/seedAdvancedCollections.ts",
    "db:seed:collection-products": "ts-node src/scripts/seedCollectionProducts.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "expo-server-sdk": "^3.11.0",
    "express": "^4.22.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.37",
    "@types/supertest": "^7.2.0",
    "@vercel/node": "^5.6.18",
    "dotenv-cli": "^7.4.2",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
