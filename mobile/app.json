{
  "expo": {
    "name": "AfroChinaTrade",
    "slug": "afrochinatrade",
    "owner": "afrochinatrade",
    "scheme": "afrochinatrade",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo_bg.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Logo_bg.png",
      "resizeMode": "contain",
      "backgroundColor": "#C41E3A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.afrochinatrade.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo_bg.png",
        "backgroundColor": "#C41E3A"
      },
      "package": "com.afrochinatrade.app"
    },
    "web": {
      "favicon": "./assets/Logo_bg.png",
      "bundler": "metro"
    },
    "extra": {
      "apiUrl": "http://localhost:3000/api",
      "router": {},
      "eas": {
        "projectId": "bf9457ce-f002-4315-9de5-c6be1affecb6"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/Logo_bg.png",
          "color": "#C41E3A"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bf9457ce-f002-4315-9de5-c6be1affecb6"
    }
  }
}
